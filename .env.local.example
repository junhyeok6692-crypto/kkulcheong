# ── 데이터 소스 ─────────────────────────────
# 정부지원사업 (기업마당) — 활용정보 > 정책정보 개방
BIZINFO_API_KEY=

# 청년정책 (온통청년) — 마이페이지 > 오픈(OPEN) API
YOUTH_API_KEY=

# 공공데이터포털 공용 키 (K-Startup, 복지서비스 등) — 일반 인증키(Decoding)
DATA_GO_KR_KEY=

# ── 배포 ───────────────────────────────────
# 실제 도메인 (예: https://kkulcheong.com) — sitemap/canonical/OG 에 사용
NEXT_PUBLIC_SITE_URL=

# ── 애드센스 ───────────────────────────────
# 승인 후 게시자 ID (예: ca-pub-1234567890123456)
# 넣으면 광고 스크립트 + ads.txt 가 자동 활성화됨
NEXT_PUBLIC_ADSENSE_CLIENT=
